#openai兼容的API-KEY
API_KEY=your_api_key_here

BASE_URL=https://api.example.com

MODEL_NAME=your_model_name

# 请求超时时间 (秒)
REQUEST_TIMEOUT=120
# 最大重试次数
MAX_RETRIES=3
# 重试延迟时间 (秒)
RETRY_DELAY=2
# 最大 Token 数
MAX_TOKENS=8192

# ------------------------------------------
# LangSmith 追踪配置 (可选)
# ------------------------------------------
# 是否启用 LangSmith 追踪 ("true" 或 "false")
LANGCHAIN_TRACING_V2=false

# LangSmith API 密钥 (如果启用追踪)
LANGCHAIN_API_KEY=your_langsmith_api_key_here

# LangSmith 项目名称
LANGCHAIN_PROJECT=miniMaster
